# Base URL of a machine running Ollama with qwen3:8b pulled.
# Defaults to http://localhost:11434 if unset.
# Point this at a LAN IP (e.g. http://192.168.1.23:11434) to reach an
# Ollama instance running on another machine on the same home network.
OLLAMA_BASE_URL=http://localhost:11434

# Defaults to qwen3:8b if unset.
OLLAMA_MODEL=qwen3:8b
