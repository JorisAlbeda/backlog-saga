# Base URL of a machine running Ollama with qwen3:8b pulled.
# Defaults to http://localhost:11434 if unset.
# Point this at a LAN IP (e.g. http://192.168.1.23:11434) to reach an
# Ollama instance running on another machine on the same home network.
OLLAMA_BASE_URL=http://localhost:11434

# Defaults to qwen3:8b if unset.
OLLAMA_MODEL=qwen3:8b

# Embedding model used to ground new world elements in the existing codex.
# Defaults to nomic-embed-text if unset — must be pulled on the Ollama host:
#   ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

# Path to the world codex folder (the `codex/` directory produced by the
# sibling `rag` project's `npm run catalogue`), absolute or relative to the
# project root. This is the one shared codex all consuming apps read AND
# write — Backlog Saga also writes its own newly-generated entries directly
# into this folder. Leave unset/empty to disable both codex grounding and
# write-back entirely.
CODEX_DIR=../rag/codex
